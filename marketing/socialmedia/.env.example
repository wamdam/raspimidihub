# Mastodon Configuration
# Copy this file to .env and fill in your credentials

# Mastodon instance URL (e.g., https://mastodon.social or https://fosstodon.org)
MASTODON_INSTANCE=https://mastodon.social

# Access token for posting
# Generate at: https://<your-instance>/settings/applications
MASTODON_ACCESS_TOKEN=your_access_token_here

# Client ID and Secret (only needed for first-time OAuth setup)
# If you already have an access token, you only need MASTODON_ACCESS_TOKEN
MASTODON_CLIENT_ID=your_client_id_here
MASTODON_CLIENT_SECRET=your_client_secret_here
