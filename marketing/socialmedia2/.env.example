# RaspiMIDIHub social announcer — copy to .env and fill in.

# --- Publishers (configure one or both; posts go to every configured one) ---
MASTODON_INSTANCE=https://mastodon.social
MASTODON_ACCESS_TOKEN=your_access_token_here

# Discord: Channel Settings -> Integrations -> Webhooks -> New Webhook -> Copy URL.
# Use the raw URL as-is (do NOT append /slack or /github — we send native JSON).
DISCORD_WEBHOOK_URL=

# --- LLM (OpenAI-compatible). Default = local vLLM on `spark`. ---
# Set SOCIAL_LLM_ENABLED=0 to skip the LLM and use plain templates.
SOCIAL_LLM_ENABLED=1
SOCIAL_LLM_BASE_URL=http://spark:8000/v1
SOCIAL_LLM_MODEL=qwen/qwen3.5-122b
SOCIAL_LLM_API_KEY=

# --- Sources ---
SOCIAL_YOUTUBE_PLAYLIST_ID=PLtvjGBXW1XVlCX-6kVOwsjVSW12kIFKJ7
SOCIAL_GITHUB_REPO=wamdam/raspimidihub
SOCIAL_GITHUB_BRANCH=main
# Optional GitHub token (only if you hit the 60 req/h unauthenticated limit):
# SOCIAL_GITHUB_TOKEN=

# Where to read CHANGELOG/README/manual/screenshots from.
# Unset = auto-detect local repo, else GitHub raw (right for the website server).
# A path forces local; a https://… raw base forces remote.
# SOCIAL_CONTENT_BASE=

# --- Schedule (seconds, used by the dispatch tick) ---
SOCIAL_INTERVAL_YOUTUBE=3600
SOCIAL_INTERVAL_GITHUB=3600
SOCIAL_INTERVAL_FEATURES=14400

# --- Misc ---
SOCIAL_SITE_URL=https://raspimidihub.com
# Where announce-state is stored (default ~/.raspimidihub/socialmedia2/):
# SOCIAL_STATE_DIR=
